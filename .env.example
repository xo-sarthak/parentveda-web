# ParentVeda website — environment variables.
# Copy to .env.local for local dev (.env* is gitignored), and set the same
# two in Vercel → Project → Settings → Environment Variables.
#
# Both are NEXT_PUBLIC_* because that is the Supabase convention and the
# values are public by design: the anon/publishable key is RLS-gated to
# status='published' rows. Nothing secret belongs in this file.
# The site only ever READS content, and only from server components.

NEXT_PUBLIC_SUPABASE_URL=https://csrabzuhxbschkeyohha.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — only for a sub-path deploy (e.g. GitHub Pages project site).
# Leave unset on Vercel / a custom domain; the site is served from the root.
# NEXT_PUBLIC_BASE_PATH=/parentveda-web
